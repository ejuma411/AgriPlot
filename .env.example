DJANGO_SECRET_KEY=replace-with-a-unique-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

DB_NAME=agriplot_db
DB_USER=agriplot_user
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432

# Set this once per environment. The project uses it for absolute links,
# notifications, payment callbacks, and webhook defaults.
SITE_URL=http://127.0.0.1:8000
SITE_NAME=AgriPlot Connect
SUPPORT_EMAIL=support@agriplot.com
SUPPORT_PHONE=+254700000000

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=replace-with-email-user
EMAIL_HOST_PASSWORD=replace-with-email-password
DEFAULT_FROM_EMAIL=AgriPlot Connect <noreply@agriplot.com>

TEXTSMS_PARTNER_ID=
TEXTSMS_API_KEY=
TEXTSMS_SENDER_ID=AgriPlot
TEXTSMS_API_URL=https://sms.textsms.co.ke/api/services/sendsms/

ARDHISASA_API_URL=
ARDHISASA_API_KEY=
ARDHISASA_MODE=mock
ARDHISASA_WEBHOOK_URL=

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=KES
PAYSTACK_ENABLED=False
PAYSTACK_AUTO_RELEASE_TEST_DEALS=True

REQUIRE_CONTACT_VERIFICATION=False
REQUIRE_2FA_FOR_LISTING=False
REQUIRE_DOCUMENT_VERIFICATION=False
REQUIRE_2FA=False
REQUIRE_2FA_ENROLLMENT=False
PLOT_CREATE_RATE_LIMIT=0
OTP_PROVIDER=email
USE_SMS_MOCK=True
